# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
# Note: use SOC_DATABASE_URL (not DATABASE_URL) to avoid colliding with any
# existing workspace Postgres DATABASE_URL in your environment.
SOC_DATABASE_URL=sqlite+aiosqlite:///./soc_memory.db

# ─── LLM Provider (pluggable) ────────────────────────────────────────────────
# Leave these blank to run in mock mode (no real LLM call is made).
# Any OpenAI-compatible provider works — set the base URL to your provider's endpoint.
#
# Examples:
#   OpenAI:      LLM_BASE_URL=https://api.openai.com/v1
#   Groq:        LLM_BASE_URL=https://api.groq.com/openai/v1
#   Ollama:      LLM_BASE_URL=http://localhost:11434/v1
#   vLLM:        LLM_BASE_URL=http://your-vllm-host:8000/v1
#   LiteLLM:     LLM_BASE_URL=http://localhost:4000/v1
#
# MemPalace integration point:
#   When you replace the SQLite memory layer with MemPalace, also add
#   MEMPALACE_API_URL and MEMPALACE_API_KEY here.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# ─── Context builder ─────────────────────────────────────────────────────────
CONTEXT_WINDOW_HOURS=24
MAX_CONTEXT_EVENTS=20

# ─── Decision thresholds ─────────────────────────────────────────────────────
BLOCK_THRESHOLD=80
ALERT_THRESHOLD=50
